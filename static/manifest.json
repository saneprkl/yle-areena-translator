{
  "manifest_version": 3,
  "name": "Areena DeepL Subtitles (Dev)",
  "version": "0.0.1",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.yle.fi/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.yle.fi/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_page": "options.html"
}
